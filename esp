function ESP:StartAutoSync(flags_table)
    if flags_table then
        self.FlagsTable = flags_table
    end
    if not self.FlagsTable then
        return
    end
    local function resolveFlags()
        local resolved = {}
        for k, v in pairs(self.FlagsTable) do
            if type(v) == "function" then
                local result = v()
                if type(result) == "table" and result.Color then
                    resolved[k] = result
                else
                    resolved[k] = result
                end
            else
                resolved[k] = v
            end
        end
        return resolved
    end
    task.spawn(function()
        while self.Connection do
            task.wait(0.05)
            local resolvedFlags = resolveFlags()
            self:SyncFromFlags(resolvedFlags)
            self:SyncSelfFromFlags(resolvedFlags)
        end
    end)
end

