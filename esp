end

function ESP:UpdateColor(settingKey, color)
    if self.Settings[settingKey] ~= nil then
        self.Settings[settingKey] = color
    end
end

function ESP:UpdateSelfColor(settingKey, color)
    if self.SelfSettings[settingKey] ~= nil then
        self.SelfSettings[settingKey] = color
    end
end

function ESP:Unload()
    if self.Connection then
        self.Connection:Disconnect()
        self.Connection = nil
    end
    for player, obj in pairs(self.Objects) do
        if obj.Highlight then
            pcall(function() obj.Highlight:Destroy() end)
            obj.Highlight = nil
        end
        DestroyESPObject(obj)
    end
    self.Objects = {}
end

